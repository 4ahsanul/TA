<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    tools:context=".ui.profile.ProfileFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <RelativeLayout
            android:id="@+id/profileInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="@dimen/spacing_xxxlarge"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <androidx.cardview.widget.CardView
                android:id="@+id/cardview_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_xlarge"
                android:layout_marginTop="80dp"
                android:layout_marginEnd="@dimen/spacing_xlarge"
                android:layout_marginBottom="@dimen/spacing_large"
                app:cardCornerRadius="@dimen/corner_radius_large"
                app:cardElevation="@dimen/card_elevation">

                <LinearLayout
                    android:id="@+id/layoutLinear"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/white"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_xlarge">

                    <EditText
                        android:id="@+id/et_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_xxxlarge"
                        android:background="@android:color/transparent"
                        android:fontFamily="@font/poppins_medium"
                        android:gravity="center"
                        android:hint="@string/name_hint"
                        android:textAppearance="@style/TextAppearance.AppCompat.Title"
                        android:textColor="@color/text_primary"
                        tools:text="@tools:sample/full_names" />

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_small">

                        <EditText
                            android:id="@+id/et_mail"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="@dimen/spacing_xxxlarge"
                            android:background="@android:color/transparent"
                            android:ems="10"
                            android:enabled="false"
                            android:fontFamily="@font/poppins_regular"
                            android:inputType="textEmailAddress"
                            android:text="@string/email_hint"
                            android:textColor="@color/text_secondary"
                            android:textSize="@dimen/text_caption"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <ImageView
                            android:id="@+id/icUnverified"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_unverified"
                            android:visibility="invisible"
                            app:layout_constraintBottom_toBottomOf="@+id/et_mail"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="@+id/et_mail" />

                        <ImageView
                            android:id="@+id/icVerified"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_verified"
                            android:visibility="invisible"
                            app:layout_constraintBottom_toBottomOf="@+id/et_mail"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="@+id/et_mail" />
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_small">

                        <EditText
                            android:id="@+id/et_phone"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@android:color/transparent"
                            android:ems="10"
                            android:enabled="false"
                            android:fontFamily="@font/poppins_regular"
                            android:inputType="phone"
                            android:text="@string/phone"
                            android:textColor="@color/text_secondary"
                            android:textSize="@dimen/text_caption"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_save"
                        style="@style/Widget.AIDentist.Button.Primary"
                        android:layout_width="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="@dimen/spacing_large"
                        android:text="Simpan Profile"
                        android:textAllCaps="false" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/avatar"
                android:layout_width="@dimen/avatar_large"
                android:layout_height="@dimen/avatar_large"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="@dimen/spacing_xlarge"
                android:src="@drawable/ic_avatar_profile_hd"
                app:civ_border_color="@color/primary"
                app:civ_border_width="@dimen/avatar_border"
                tools:src="@tools:sample/avatars" />
        </RelativeLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonHistory"
            style="@style/Widget.AIDentist.Button.Secondary"
            android:layout_width="0dp"
            android:layout_marginHorizontal="@dimen/spacing_xxxlarge"
            android:layout_marginTop="@dimen/spacing_large"
            android:drawableStart="@drawable/ic_history_coco"
            android:drawableTint="@color/primary"
            android:fontFamily="@font/poppins_medium"
            android:text="@string/history"
            android:textAllCaps="false"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/profileInfo" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonLogout"
            style="@style/Widget.AIDentist.Button.Danger"
            android:layout_width="0dp"
            android:layout_marginHorizontal="@dimen/spacing_xxxlarge"
            android:layout_marginTop="@dimen/spacing_medium"
            android:layout_marginBottom="@dimen/spacing_xxxlarge"
            android:fontFamily="@font/poppins_medium"
            android:text="@string/log_out"
            android:textAllCaps="false"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/buttonHistory" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
