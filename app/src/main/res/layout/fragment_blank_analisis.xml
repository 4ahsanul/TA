<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <androidx.cardview.widget.CardView
            android:id="@+id/infoData"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/spacing_medium"
            app:cardCornerRadius="@dimen/corner_radius_large"
            app:cardElevation="@dimen/card_elevation"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:id="@+id/layoutCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/white"
                android:orientation="vertical"
                android:padding="@dimen/spacing_xlarge">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="170dp"
                    android:contentDescription="@string/image_guide"
                    android:scaleType="fitCenter"
                    android:src="@drawable/picture_illustration" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_camera"
                    style="@style/Widget.AIDentist.Button.Primary"
                    android:layout_width="match_parent"
                    android:layout_marginVertical="@dimen/spacing_medium"
                    android:drawableLeft="@drawable/ic_baseline_center_focus_weak_24"
                    android:drawableTint="@color/white"
                    android:text="@string/check_oral_health"
                    android:textAllCaps="false" />

                <TextView
                    android:id="@+id/tosText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_small"
                    android:fontFamily="@font/poppins_regular"
                    android:text="@string/guide_home1"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_caption" />

                <TextView
                    android:id="@+id/tosText2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_small"
                    android:fontFamily="@font/poppins_regular"
                    android:text="@string/guide_home2"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_caption" />

                <TextView
                    android:id="@+id/tosText3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_small"
                    android:fontFamily="@font/poppins_regular"
                    android:text="@string/guide_home3"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_caption" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
